# Enforce LF in repository for all text files (cross-platform consistency)
* text=auto eol=lf

# Explicitly declare text files
*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf
*.sh   text eol=lf
Dockerfile text eol=lf

# Binary files — never convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.bin  binary
*.sqlite3 binary
