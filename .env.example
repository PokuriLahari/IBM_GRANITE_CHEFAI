# ─────────────────────────────────────────────────
# IBM Watsonx.ai Credentials
# ─────────────────────────────────────────────────
# Obtain from: https://cloud.ibm.com → Manage → Access (IAM) → API keys
IBM_API_KEY=your_ibm_api_key_here

# Obtain from: Watsonx.ai project → Manage → General → Project ID
IBM_PROJECT_ID=your_project_id_here

# Regional endpoint — set to your IBM Cloud region:
#   us-south  → https://us-south.ml.cloud.ibm.com
#   eu-de     → https://eu-de.ml.cloud.ibm.com
#   jp-tok    → https://jp-tok.ml.cloud.ibm.com
#   au-syd    → https://au-syd.ml.cloud.ibm.com
IBM_URL=https://au-syd.ml.cloud.ibm.com

# Model for text generation.
# The app queries /ml/v1/foundation_model_specs at startup and auto-selects
# the first available text_generation model if the configured one is absent.
#
# au-syd text_generation models (verified July 2025):
#   ibm/granite-8b-code-instruct   ← Granite, deprecated 2026-05-05, withdrawn 2026-08-08
#   ibm/granite-guardian-3-8b      ← Granite, deprecated 2026-05-05, withdrawn 2026-08-08
#   meta-llama/llama-3-3-70b-instruct ← Llama, fully available (best quality)
#
# NOTE: ibm/granite-3-1-8b-base is a fine-tuning base model — it has NO
#       text_generation function and CANNOT be used for inference directly.
#
# us-south Granite text_generation models:
#   ibm/granite-3-8b-instruct      ← recommended for us-south
#   ibm/granite-4-h-small
MODEL_ID=ibm/granite-8b-code-instruct

# ─────────────────────────────────────────────────
# Flask Configuration
# ─────────────────────────────────────────────────
FLASK_ENV=production
FLASK_SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DEBUG=false

# ─────────────────────────────────────────────────
# ChromaDB Configuration
# ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─────────────────────────────────────────────────
# RAG Configuration
# ─────────────────────────────────────────────────
TOP_K_RESULTS=5
EMBEDDING_MODEL=all-MiniLM-L6-v2
